@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Tarefas";
}

@model List<ListarTarefaViewModel>

<div class="d-flex justify-content-between align-items-center mb-4">

    <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Cadastrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-lg me-1"
             viewBox="0 0 16 16">
            <path fill-rule="evenodd"
                  d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z" />
        </svg>
        Cadastrar Nova
    </a>


    <div class="btn-group">

        <a class="btn btn-outline-primary" asp-action="Listar" asp-route-filtro="todas">
            Todas
        </a>

        <a class="btn btn-outline-success" asp-action="Listar" asp-route-filtro="concluidas">
            Concluídas
        </a>

        <a class="btn btn-outline-warning" asp-action="Listar" asp-route-filtro="prioridade">
            Prioridade
        </a>

    </div>

</div>


@if (TempData["MensagemErro"] is string erro)
{
    <div class="alert alert-danger">
        @erro
    </div>
}

@if (TempData["MensagemSucesso"] is string sucesso)
{
    <div class="alert alert-success">
        @sucesso
    </div>
}


@if (!Model.Any())
{
    <div class="alert alert-info">
        Nenhuma tarefa encontrada.
    </div>
}
else
{

    <div class="row g-4">

        @foreach (var tarefa in Model)
        {
            var idCurto = tarefa.Id.ToString("N")[..7];


            <div class="col-md-6 col-lg-4">

                <div class="card h-100 shadow-sm">


                    <div class="card-header bg-primary text-white 
                        d-flex justify-content-between align-items-center">

                        <strong>
                            @tarefa.Titulo
                        </strong>

                        <span class="badge bg-light text-dark">
                            #@idCurto
                        </span>

                    </div>


                    <div class="card-body">


                        <p>
                            <strong>Prioridade:</strong>
                            @tarefa.Prioridade
                        </p>


                        <p>
                            <strong>Criação:</strong>
                            @tarefa.DataDeCriacao.ToString("dd/MM/yyyy")
                        </p>


                        <p>
                            <strong>Status:</strong>

                            @if (tarefa.StatusDeConclusao == StatusDeConclusao.Concluido)
                            {
                                <span class="badge bg-success">
                                    Concluída
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    @tarefa.StatusDeConclusao
                                </span>
                            }

                        </p>


                        <p>
                            <strong>Conclusão:</strong>

                            @(tarefa.DataDeConclusao == DateTime.MinValue
                                ? "-"
                                : tarefa.DataDeConclusao.ToString("dd/MM/yyyy"))
                        </p>



                        <p>
                            <strong>Percentual:</strong>

                            <div class="progress">

                                <div class="progress-bar bg-success" role="progressbar"
                                     style="width:@(tarefa.PercentualConcluido)%">

                                    @tarefa.PercentualConcluido%

                                </div>

                            </div>

                        </p>


                    </div>



                    <div class="card-footer bg-white">


                        <div class="d-grid gap-2">


                            <a class="btn btn-success" asp-controller="Item" asp-action="Listar"
                               asp-route-tarefaId="@tarefa.Id">

                                Itens

                            </a>



                            <div class="btn-group">


                                <a class="btn btn-primary" asp-action="Editar" asp-route-id="@tarefa.Id">

                                    Editar

                                </a>



                                <a class="btn btn-outline-danger" asp-action="Excluir" asp-route-id="@tarefa.Id">

                                    Excluir

                                </a>


                            </div>


                        </div>


                    </div>


                </div>


            </div>
        }

    </div>

}



<style>
    .card {
        transition: all .2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .75rem 1.5rem rgba(0, 0, 0, .15);
    }
</style>