@using eAgendaWeb.WebApplication.ModuloDispesa.Apresentacao
@using eAgendaWeb.WebApplication.ModuloDispesa.Dominio
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Despesa";
}

@model CadastrarDespesaViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Cadastrar"
      method="post">

    <h4 class="text-primary mb-4">Cadastrar Despesa</h4>


    <div class="mb-3">
        <label asp-for="Descricao" class="form-label fw-semibold text-primary text-uppercase small">
            Descrição
        </label>

        <input asp-for="Descricao" type="text" class="form-control">

        <span asp-validation-for="Descricao" class="text-danger small fw-semibold">
        </span>
    </div>


    <div class="mb-3">
        <label asp-for="DataDeOcorrencia" class="form-label fw-semibold text-primary text-uppercase small">
            Data de Ocorrência
        </label>

        <input asp-for="DataDeOcorrencia" type="date" class="form-control">

        <span asp-validation-for="DataDeOcorrencia" class="text-danger small fw-semibold">
        </span>
    </div>


    <div class="mb-3">
        <label asp-for="Valor" class="form-label fw-semibold text-primary text-uppercase small">
            Valor
        </label>

        <input asp-for="Valor" type="number" step="0.01" class="form-control">

        <span asp-validation-for="Valor" class="text-danger small fw-semibold">
        </span>
    </div>


    <div class="mb-3">
        <label asp-for="FormaDePagamento" class="form-label fw-semibold text-primary text-uppercase small">
            Forma de Pagamento
        </label>

        <select asp-for="FormaDePagamento" class="form-select">
            <option value="">Selecione uma forma de pagamento</option>

            @foreach (FormaDePagamento forma in Enum.GetValues<FormaDePagamento>())
            {
                <option value="@forma">@forma</option>
            }

        </select>

        <span asp-validation-for="FormaDePagamento" class="text-danger small fw-semibold">
        </span>
    </div>


    <div class="mb-3">

        <label asp-for="CategoriaIds" class="form-label fw-semibold text-primary text-uppercase small">
            Categorias
        </label>


        <select asp-for="CategoriaIds" class="form-select" multiple>

            @foreach (OpcaoCategoriaViewModel categoria in Model.Categorias)
            {
                <option value="@categoria.Id">
                    @categoria.Titulo
                </option>
            }

        </select>

        <span asp-validation-for="CategoriaIds" class="text-danger small fw-semibold">
        </span>

    </div>


    <div class="d-flex justify-content-end gap-2 mt-4">

        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">
            Voltar
        </a>

        <button class="btn btn-success rounded-pill px-4" type="submit">
            Confirmar
        </button>

    </div>

</form>
