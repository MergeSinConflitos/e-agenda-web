@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Categorias";
}

@model List<ListarCategoriaViewModel>

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-lg me-1"
         viewBox="0 0 16 16">
        <path fill-rule="evenodd"
              d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z" />
    </svg>
    Cadastrar Nova
</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (TempData["MensagemSucesso"] is string mensagemSucesso)
{
    <div class="alert alert-success border-start border-success border-4 rounded-3" role="alert">
        @mensagemSucesso
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Nenhuma categoria cadastrada.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach (var categoria in Model)
        {
            var idCurto = categoria.Id.ToString("N")[..7];

            <div class="col">
                <div class="card h-100 shadow-sm border-0" style="transition: all .3s ease;">

                    <div class="card-header border-0 bg-primary" style="height:8px;"></div>

                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title mb-0">@categoria.Titulo</h5>

                            <span class="badge rounded-pill bg-primary">
                                #@idCurto
                            </span>
                        </div>

                    </div>

                    <div class="card-footer bg-transparent border-0 pt-0 pb-3">
                        <div class="d-grid gap-2 d-md-flex">
                            <a class="btn btn-primary btn-sm flex-fill" asp-action="Editar" asp-route-id="@categoria.Id">
                                Editar
                            </a>

                            <a class="btn btn-outline-danger btn-sm flex-fill" asp-action="Excluir"
                               asp-route-id="@categoria.Id">
                                Excluir
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
}

<style>
    .card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, .15) !important;
    }
</style>