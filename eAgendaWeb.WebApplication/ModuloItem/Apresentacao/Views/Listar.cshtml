@{
    Layout = "_Layout";
    ViewBag.Titulo = "Itens da Tarefa";
}

@model GerenciarItemViewModel


<a class="btn btn-outline-success rounded-pill px-4 mb-3" asp-action="Cadastrar" asp-route-tarefaId="@Model.TarefaId">

    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-plus-lg me-1"
         viewBox="0 0 16 16">

        <path fill-rule="evenodd"
              d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z" />

    </svg>

    Novo Item

</a>


@if (TempData["MensagemErro"] is string erro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3">
        @erro
    </div>
}


@if (TempData["MensagemSucesso"] is string sucesso)
{
    <div class="alert alert-success border-start border-success border-4 rounded-3">
        @sucesso
    </div>
}



@if (!Model.Itens.Any())
{
    <div class="alert alert-warning border-start border-warning border-2 rounded-3">

        Nenhum item cadastrado para esta tarefa.

    </div>
}
else
{

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">


        @foreach (var item in Model.Itens)
        {

            var idCurto = item.Id.ToString("N")[..7];


            <div class="col">


                <div class="card h-100 shadow-sm border-0">


                    <div class="card-header bg-success" style="height:8px;">
                    </div>



                    <div class="card-body">


                        <div class="d-flex justify-content-between align-items-start mb-3">


                            <h5 class="card-title mb-0">
                                Item
                            </h5>


                            <span class="badge rounded-pill bg-secondary">
                                #@idCurto
                            </span>


                        </div>



                        <div class="mb-3">

                            <small class="text-muted">

                                <strong>Título:</strong>

                                <br />

                                @item.Titulo

                            </small>

                        </div>



                        <div class="mb-3">

                            <small class="text-muted">

                                <strong>Status:</strong>

                                @item.StatusDeConclusao

                            </small>

                        </div>


                    </div>




                    <div class="card-footer bg-transparent border-0 pb-3">


                        @if (item.StatusDeConclusao != StatusDeConclusao.Concluido)
                        {

                            <form asp-action="Concluir" method="post" class="mb-2">


                                <input type="hidden" name="id" value="@item.Id" />


                                <input type="hidden" name="tarefaId" value="@item.TarefaId" />


                                <button class="btn btn-success btn-sm w-100 rounded-pill">

                                    ✓ Concluir

                                </button>


                            </form>

                        }
                        else
                        {

                            <div class="text-center mb-2">

                                <span class="badge bg-success rounded-pill px-4 py-2">

                                    Concluído

                                </span>

                            </div>

                        }



                        <a class="btn btn-outline-danger btn-sm w-100 rounded-pill" asp-action="Excluir"
                           asp-route-id="@item.Id">

                            Excluir

                        </a>


                    </div>


                </div>


            </div>

        }


    </div>

}



<style>
    .card {
        transition: .2s;
    }


    .card:hover {

        transform: translateY(-4px);

        box-shadow: 0 8px 16px rgba(0, 0, 0, .15) !important;

    }
</style>